\contentsline {figure}{\numberline {2.29}{\ignorespaces Illustrazione del framework complessivo di CAIT, che integra simultaneamente le operazioni di ATME e CDCP. Fonte:~\blx@tocontentsinit {0}\cite {wang2025caittriplewincompressionhigh}.}}{51}{figure.caption.67}%
